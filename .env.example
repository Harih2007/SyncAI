# Environment variables for the GenAI Meeting Preparation Assistant
# Copy this file to .env and fill in your values

# Google Cloud project ID (required)
PROJECT_ID=your-gcp-project-id

# Path to service account key JSON (local development only)
# On Cloud Run, ADC is automatically available — do NOT set this variable
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Gemini model to use via Vertex AI (optional, defaults to gemini-2.0-flash)
VERTEX_MODEL=gemini-2.0-flash
